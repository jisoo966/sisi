# Sísí — Environment Variables Template
# Copy this to .env.local and fill in your keys
# DO NOT commit .env.local to git

# =============================================
# Supabase
# =============================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# =============================================
# AI APIs
# =============================================
ANTHROPIC_API_KEY=sk-ant-xxxxx
FAL_API_KEY=xxxxx

# ElevenLabs
ELEVENLABS_API_KEY=sk_xxxxx
# Sísí voice IDs (3 personas) — get these from ElevenLabs Voice Library
ELEVENLABS_VOICE_SISI_SOFT=xxxxx
ELEVENLABS_VOICE_SISI_WHISPER=xxxxx
ELEVENLABS_VOICE_SISI_GROUNDED=xxxxx

# =============================================
# Push + Email
# =============================================
ONESIGNAL_APP_ID=xxxxx
ONESIGNAL_REST_API_KEY=xxxxx
RESEND_API_KEY=re_xxxxx

# =============================================
# Stripe
# =============================================
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
# Stripe Price IDs for subscription tiers
STRIPE_PRICE_ID_MONTHLY=price_xxxxx
STRIPE_PRICE_ID_ANNUAL=price_xxxxx

# =============================================
# Analytics
# =============================================
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# =============================================
# App
# =============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://hellosisi.co
